# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
jspm_packages/
bower_components/

# Keep the committed npm lockfile. Ignore the alternatives so they do not
# get accidentally committed from a different workstation.
yarn.lock
pnpm-lock.yaml
bun.lockb

# ---------------------------------------------------------------------------
# Next.js / build output
# ---------------------------------------------------------------------------
/.next/
/out/
/build
/dist
.swc/
.turbo/
.vercel/

# Next auto-generates this file on `next dev`/`next build`.
next-env.d.ts

# ---------------------------------------------------------------------------
# TypeScript / ESLint / Prettier caches
# ---------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo
.eslintcache
.stylelintcache
.prettiercache

# ---------------------------------------------------------------------------
# Testing / coverage
# ---------------------------------------------------------------------------
/coverage
*.lcov
.nyc_output/
/playwright-report
/test-results
playwright/.cache/

# ---------------------------------------------------------------------------
# Logs and runtime diagnostics
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.next-dev.log
.next-dev.err.log

# ---------------------------------------------------------------------------
# Environment files - secrets stay local; only the example is shared.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Local dev-stub data (populated at runtime; do not commit user data)
# ---------------------------------------------------------------------------
backend/data/sent-emails.json
backend/data/enrollment-requests.json

# If you add more JSON caches next to the stubs, they land here too.
backend/data/*.local.json

# Local DB export snapshots — contain user data + password hashes, never commit.
advancia-db-export-*/

# ---------------------------------------------------------------------------
# Generated artifacts that can be rebuilt from source
# ---------------------------------------------------------------------------
/generated_word_charts
_doc_export.txt
/backend/exports/output/

# LaTeX build output (docs/ contains .tex sources)
*.aux
*.fdb_latexmk
*.fls
*.out
*.synctex.gz
*.toc

# ---------------------------------------------------------------------------
# Editor / IDE / tooling state
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# Claude Code / agent local state
.claude/settings.local.json
.claude/cache/
.claude/tasks/

# ---------------------------------------------------------------------------
# Cache directories
# ---------------------------------------------------------------------------
.cache/
.parcel-cache/
.rollup.cache/
.webpack/

# ---------------------------------------------------------------------------
# Certificates / secrets
# ---------------------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx

# ---------------------------------------------------------------------------
# OS cruft
# ---------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# OneDrive / cloud-sync temp files (this project lives under OneDrive)
.tmp.driveupload
.tmp.drivedownload
*.tmp

# Linux
*~

# ---------------------------------------------------------------------------
# Editor backup / swap files
# ---------------------------------------------------------------------------
*.swp
*.swo
*.swn
*.bak
*.orig
*~$*
